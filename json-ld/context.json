      "@id": "wormhole:sourceChain",
      "@type": "xsd:integer"
    },
    "targetChain": {
      "@id": "wormhole:targetChain",
      "@type": "xsd:integer"
    },
    "tokenAmount": {
      "@id": "wormhole:tokenAmount",
      "@type": "xsd:string"
    },
    "tokenAddress": {
      "@id": "wormhole:tokenAddress",
      "@type": "xsd:string"
    },
    "fromAddress": {
      "@id": "wormhole:fromAddress",
      "@type": "xsd:string"
    },
    "toAddress": {
      "@id": "wormhole:toAddress",
      "@type": "xsd:string"
